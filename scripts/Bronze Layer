/*
===============================================================================
BRONZE LAYER DATA LOAD SCRIPT
===============================================================================
Purpose: 
    1. Define the structure for raw data tables (Bronze Layer).
    2. Empty any existing data to avoid duplicates.
    3. Load fresh data from local CSV files.
===============================================================================
*/

CREATE TABLE IF NOT EXISTS bronze.crm_cust_info(
	cst_id INT,
	cst_key NVARCHAR(50),
	cst_firstname NVARCHAR(50),
	cst_lastname NVARCHAR(50),
	cst_marital_status NVARCHAR(50),
	cst_gndr NVARCHAR(50),
	cst_create_date NVARCHAR(50)
);

CREATE TABLE IF NOT EXISTS bronze.crm_prd_info(
	prd_id INT,
	prd_key NVARCHAR(50),
	prd_nm NVARCHAR(50),
	prd_cost DECIMAL(10, 2),
	prd_line VARCHAR(5),
	prd_start_dt DATE,
	prd_end_dt DATE
);

CREATE TABLE IF NOT EXISTS bronze.crm_sales_details(
	 sls_ord_num NVARCHAR(50),
	 sls_prd_key NVARCHAR(50),
	sls_cust_id INT,
	sls_order_dt INT,
	sls_ship_dt INT,
	sls_due_dt INT,
	sls_sales DECIMAL(10,2),
	sls_quantity INT,
	sls_price DECIMAL(10,2)
);

CREATE TABLE IF NOT EXISTS bronze.erp_CUST_AZ12(
	CID NVARCHAR(50),
	BDATE DATE,
	GEN VARCHAR(10)
);


CREATE TABLE IF NOT EXISTS bronze.erp_LOC_A101(
	CID NVARCHAR(50),
	CNTRY NVARCHAR(100)
);


CREATE TABLE IF NOT EXISTS bronze.PX_CAT_G1V2(
	ID nvarchar(50),
    CAT nvarchar(100),
    SUBCAT nvarchar(100),	
    MAINTENANCE nvarchar(5)
);

-- Loading the data into the table
-- Ensure the server is ready for the local loading
SET GLOBAL LOCAL_INFILE = 1;

-- i. Load CRM Customer information
TRUNCATE TABLE bronze.crm_cust_info;
LOAD DATA LOCAL INFILE "C:/Users/user/Desktop/YIV/Masters/SQL/SQL with barra/sql-data-warehouse-project/datasets/source_crm/cust_info.csv"
	INTO TABLE bronze.crm_cust_info
	FIELDS terminated by ","
	LINES TERMINATED BY '\r\n'
	IGNORE 1 ROWS ; 
	
-- ii. Load CRM Products information
TRUNCATE TABLE bronze.crm_prd_info;
LOAD DATA LOCAL INFILE "C:/Users/user/Desktop/YIV/Masters/SQL/SQL with barra/sql-data-warehouse-project/datasets/source_crm/prd_info.csv"
	INTO TABLE bronze.crm_prd_info
	FIELDS TERMINATED BY ','
	LINES terminated by '\r\n'
	IGNORE 1 ROWS;

-- iii. Load CRM Sales details information
TRUNCATE TABLE bronze.crm_sales_details;
LOAD DATA LOCAL INFILE "C:/Users/user/Desktop/YIV/Masters/SQL/SQL with barra/sql-data-warehouse-project/datasets/source_crm/sales_details.csv"
	INTO TABLE bronze.crm_sales_details
	FIELDS TERMINATED BY ","
	IGNORE 1 ROWS;


-- iv. Load ERP Customer AZ12
TRUNCATE TABLE bronze.erp_CUST_AZ12;
LOAD DATA LOCAL INFILE "C:/Users/user/Desktop/YIV/Masters/SQL/SQL with barra/sql-data-warehouse-project/datasets/source_erp/CUST_AZ12.csv"
	INTO TABLE bronze.erp_CUST_AZ12
	FIELDS TERMINATED BY ","
	IGNORE 1 ROWS;

-- v. Load ERP Location A101
TRUNCATE TABLE bronze.erp_LOC_A101;
LOAD DATA LOCAL INFILE "C:/Users/user/Desktop/YIV/Masters/SQL/SQL with barra/sql-data-warehouse-project/datasets/source_erp/LOC_A101.csv"
	INTO TABLE bronze.erp_LOC_A101
	FIELDS TERMINATED BY ','
	IGNORE 1 ROWS;

-- vi. Load ERP Category G1V2
TRUNCATE TABLE bronze.PX_CAT_G1V2;
LOAD DATA LOCAL INFILE "C:/Users/user/Desktop/YIV/Masters/SQL/SQL with barra/sql-data-warehouse-project/datasets/source_erp/PX_CAT_G1V2.csv"
	INTO TABLE bronze.PX_CAT_G1V2
	FIELDS terminated by ','
	IGNORE 1 ROWS;

