/*
===============================================================================
Quality Assurance Script: Silver & Gold Layer Validation
===============================================================================
Purpose: 
    To validate data integrity, consistency, and business logic across 
    the CRM, ERP, and Gold layers.
    
Expectation: 
    Ideally, these queries should return no results (empty sets) unless 
    investigating specific data distributions.
===============================================================================
*/

-- ============================================================================
-- 1. CRM Layer Validations
-- ============================================================================

-- Check for unexpected records in Product Info
SELECT * FROM silver.crm_prd_info;

-- Check distribution of Gender and Marital Status to identify outliers or nulls
SELECT DISTINCT cst_gndr FROM silver.crm_cust_info;
SELECT DISTINCT cst_marital_status FROM silver.crm_cust_info;

-- ----------------------------------------------------------------------------
-- Sales Details Validation
-- ----------------------------------------------------------------------------

-- Validate 'Order Date' length (Expectation: YYYYMMDD format / 8 characters)
SELECT * FROM silver.crm_sales_details 
WHERE LENGTH(CAST(sls_order_dt AS VARCHAR)) < 8 
  AND sls_order_dt IS NOT NULL;

-- Validate 'Shipment Date': Check for invalid zeros or negative values
SELECT sls_ship_dt 
FROM silver.crm_sales_details 
WHERE sls_ship_dt <= 0;

-- Validate 'Shipment Date' length
SELECT sls_ship_dt 
FROM silver.crm_sales_details 
WHERE LENGTH(CAST(sls_ship_dt AS VARCHAR)) < 8 
  AND sls_ship_dt IS NOT NULL;

-- Validate 'Due Date': Check for invalid zeros or negative values
SELECT sls_due_dt 
FROM silver.crm_sales_details 
WHERE sls_due_dt <= 0;

-- Validate 'Due Date' length
SELECT sls_due_dt 
FROM silver.crm_sales_details 
WHERE LENGTH(CAST(sls_due_dt AS VARCHAR)) < 8;

-- Validate 'Sales' amount: Check for negative values
SELECT sls_sales 
FROM silver.crm_sales_details 
WHERE sls_sales < 0;

-- Logic Check: Ensure Order Date is not after Shipment or Due Date
SELECT sls_order_dt, sls_ship_dt, sls_due_dt
FROM silver.crm_sales_details
WHERE sls_order_dt > sls_ship_dt 
   OR sls_order_dt > sls_due_dt;

-- Financial Consistency: Check for zero, negative, or NULL values in core metrics
SELECT sls_sales, sls_price, sls_quantity
FROM silver.crm_sales_details
WHERE sls_sales <= 0 OR sls_sales IS NULL 
   OR sls_price <= 0 OR sls_price IS NULL 
   OR sls_quantity <= 0 OR sls_quantity IS NULL;

-- ============================================================================
-- 2. ERP Layer Validations
-- ============================================================================

-- Check for leading/trailing whitespaces in Customer IDs
SELECT CID 
FROM silver.erp_cust_az12 
WHERE CID != TRIM(CID);

-- Logic Check: Ensure Birthdates are not in the future
SELECT DISTINCT BDATE 
FROM silver.erp_cust_az12 
WHERE BDATE > CURRENT_DATE;

-- Check Gender consistency in ERP source
SELECT DISTINCT GEN FROM silver.erp_cust_az12;

-- Review Location data
SELECT * FROM silver.erp_loc_a101;
SELECT DISTINCT CNTRY FROM silver.erp_loc_a101;

-- ============================================================================
-- 3. Gold Layer (Final Dimensions & Facts) Validations
-- ============================================================================

-- Check for standardized values in the final Customer Dimension
SELECT DISTINCT gender FROM gold.dim_customers;

-- Referential Integrity Check: Ensure every sale has a matching product
-- Expectation: No results (Checks for orphaned records in Fact Sales)
SELECT f.product_key 
FROM gold.fact_sales f
LEFT JOIN gold.dim_products p ON p.product_key = f.product_key
WHERE p.product_key IS NULL;

-- Referential Integrity Check: Ensure every sale has a matching customer
SELECT f.customer_key 
FROM gold.fact_sales f
LEFT JOIN gold.dim_customers c ON c.customer_key = f.customer_key
WHERE c.customer_key IS NULL;
